<Window x:Class="BacnetSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BacnetSim.ViewModels"
        xmlns:models="clr-namespace:BacnetSim.Models"
        Title="NeeshiBacnetSim"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0F1117"
        Foreground="#E2E8F0"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- ══ Color palette ══ -->
        <SolidColorBrush x:Key="BgDark"       Color="#0F1117"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgCard"       Color="#22263A"/>
        <SolidColorBrush x:Key="BgInput"      Color="#2D3250"/>
        <SolidColorBrush x:Key="Accent"       Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHover"  Color="#6D28D9"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentAmber"  Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#94A3B8"/>
        <SolidColorBrush x:Key="Border"       Color="#334155"/>

        <!-- ══ Label style ══ -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>

        <!-- ══ Input box style ══ -->
        <Style x:Key="Input" TargetType="Control">
            <Setter Property="Background"          Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"          Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"         Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="8,5"/>
            <Setter Property="Height"              Value="32"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource Input}">
            <Setter Property="CaretBrush"          Value="{StaticResource TextPrimary}"/>
        </Style>
        <!-- ══ Dark ComboBox ══ -->
        <Style TargetType="ComboBox" BasedOn="{StaticResource Input}">
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"    Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"        Value="32"/>
            <Setter Property="Padding"       Value="8,5"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E2E8F0"/>
                        <Setter Property="Background" Value="#2D3250"/>
                        <Setter Property="Padding"    Value="10,7"/>
                        <Setter Property="FontSize"   Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#7C3AED"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#6D28D9"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Main border -->
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"/>
                            <!-- Invisible toggle covers the whole control -->
                            <ToggleButton x:Name="ToggleBtn"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"/>
                            <!-- Selected item display -->
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,30,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <!-- Arrow -->
                            <TextBlock Text="▾"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="#94A3B8"
                                       IsHitTestVisible="False"/>
                            <!-- Dark popup dropdown -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#2D3250"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="0,0,6,6"
                                        MinWidth="{Binding ActualWidth,
                                            RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Button base ══ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"         Value="White"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="Padding"            Value="16,8"/>
            <Setter Property="Height"             Value="36"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="FontWeight"         Value="SemiBold"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
        </Style>
        <Style x:Key="BtnGreen"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
        </Style>
        <Style x:Key="BtnRed"     TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="BtnAmber"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentAmber}"/>
        </Style>
        <Style x:Key="BtnGhost"   TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
        </Style>

        <!-- ══ DataGrid ══ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="GridLinesVisibility"  Value="None"/>
            <Setter Property="RowBackground"        Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2235"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="CanUserDeleteRows"    Value="False"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#181B29"/>
            <Setter Property="Foreground"    Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding"       Value="10,6"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"   Value="{StaticResource Border}"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#312E81"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TypeLabel badge ══ -->
        <Style x:Key="TypeBadge" TargetType="Border">
            <Setter Property="CornerRadius"   Value="4"/>
            <Setter Property="Padding"        Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- ══ Section title ══ -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin"     Value="0,0,0,12"/>
        </Style>

        <!-- ══ Card border ══ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"  Value="10"/>
            <Setter Property="Padding"       Value="18"/>
            <Setter Property="BorderBrush"   Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- top bar -->
            <RowDefinition Height="*"/>    <!-- content -->
            <RowDefinition Height="180"/>  <!-- log -->
            <RowDefinition Height="32"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 0 – Top bar
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource Accent}" Margin="0,0,12,0">
                        <TextBlock Text="B" FontSize="20" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="NeeshiBacnetSim" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Virtual BACnet/IP Device" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Device config inline -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="Device ID" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Device.DeviceInstance, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" IsEnabled="{Binding IsNotRunning}"/>
                    <TextBlock Text="Name" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox Text="{Binding Device.DeviceName, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" IsEnabled="{Binding IsNotRunning}"/>
                    <TextBlock Text="Port" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox Text="{Binding Device.Port, UpdateSourceTrigger=PropertyChanged}"
                             Width="60" IsEnabled="{Binding IsNotRunning}"/>
                </StackPanel>

                <!-- Start / Stop buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <TextBlock Text="{Binding StatusLed}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="▶  Start" Style="{StaticResource BtnGreen}"
                            Command="{Binding StartCommand}" Width="100" Margin="0,0,8,0"/>
                    <Button Content="■  Stop"  Style="{StaticResource BtnRed}"
                            Command="{Binding StopCommand}"  Width="100"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 1 – Main content
             ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,14,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Add Point Form ──────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,6,0">
                    <TextBlock Style="{StaticResource SectionTitle}">➕  Add Point</TextBlock>

                    <TextBlock Style="{StaticResource Label}">Point Name</TextBlock>
                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource Label}">Object Type</TextBlock>
                    <ComboBox ItemsSource="{Binding ObjectTypes}"
                              SelectedItem="{Binding NewType}" Margin="0,0,0,10"
                              SelectionChanged="ObjectTypeComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimary}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Style="{StaticResource Label}">Instance #</TextBlock>
                    <TextBox Text="{Binding NewInstance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource Label}">Initial Value</TextBlock>
                    <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource Label}">Engineering Units</TextBlock>
                    <TextBox Text="{Binding NewUnits, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"
                             ToolTip="e.g. °C, %, RPM, kW"/>

                    <TextBlock Style="{StaticResource Label}">Description</TextBlock>
                    <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                    <!-- ── Value Simulation (analog points only) ── -->
                    <StackPanel Visibility="{Binding IsNewTypeAnalog, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Label}">Value Generation</TextBlock>
                        <ComboBox ItemsSource="{Binding SimulationModes}"
                                  SelectedItem="{Binding NewSimulationMode}" Margin="0,0,0,10"
                                  ToolTip="Static = manual · Random = random within range · Increment = rise by random step">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimary}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Visibility="{Binding IsRandomConfigVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource Label}">Min</TextBlock>
                                    <TextBox Text="{Binding NewSimMin, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource Label}">Max</TextBlock>
                                    <TextBox Text="{Binding NewSimMax, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Increment-only: random step range added every 5 s (value only rises) -->
                        <StackPanel Visibility="{Binding IsIncrementConfigVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource Label}">Increment Step (per 5 s)</TextBlock>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource Label}">Step Min</TextBlock>
                                    <TextBox Text="{Binding NewSimStepMin, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Smallest random amount added each tick, e.g. 0.5"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource Label}">Step Max</TextBlock>
                                    <TextBox Text="{Binding NewSimStepMax, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Largest random amount added each tick, e.g. 1.5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Add Point" Style="{StaticResource BtnPrimary}"
                            Command="{Binding AddPointCommand}" HorizontalAlignment="Stretch"/>

                    <Separator Margin="0,16" Background="{StaticResource Border}"/>

                    <!-- Persist buttons -->
                    <TextBlock Style="{StaticResource SectionTitle}" FontSize="12">💾  Persistence</TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Save" Style="{StaticResource BtnGhost}"
                                Command="{Binding SaveCommand}" FontSize="12"/>
                        <Button Grid.Column="2" Content="Load" Style="{StaticResource BtnGhost}"
                                Command="{Binding LoadCommand}" FontSize="12"/>
                    </Grid>

                    <Separator Margin="0,16" Background="{StaticResource Border}"/>

                    <!-- Remove selected -->
                    <Button Content="🗑 Remove Selected" Style="{StaticResource BtnAmber}"
                            Command="{Binding RemovePointCommand}"
                            CommandParameter="{Binding SelectedPoint}"
                            HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── Right: Points DataGrid ─────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header bar -->
                    <Border Grid.Row="0" Background="#181B29" CornerRadius="10,10,0,0" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Title + count badge -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SectionTitle}" Margin="0" Text="📋  Configured Points"/>
                                <Border Background="{StaticResource Accent}" CornerRadius="12" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PointsCountLabel}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <!-- Edit hint -->
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Style="{StaticResource Label}" Margin="12,0,12,0"
                                       Text="Double-click Present Value to edit"/>

                            <!-- Search box -->
                            <Grid Grid.Column="2" Width="240" VerticalAlignment="Center">
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,5,28,5" VerticalContentAlignment="Center"
                                         ToolTip="Search by name, type, instance, units or description"/>
                                <TextBlock Text="🔍  Search points…" IsHitTestVisible="False"
                                           Foreground="{StaticResource TextMuted}" Margin="11,0,0,0"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="✕" Command="{Binding ClearSearchCommand}"
                                        Style="{StaticResource BtnBase}"
                                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                                        Width="24" Height="24" Padding="0" FontSize="12"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                        ToolTip="Clear search"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="PointsGrid"
                              ItemsSource="{Binding Points}"
                              SelectedItem="{Binding SelectedPoint}"
                              CellEditEnding="DataGrid_CellEditEnding"
                              Margin="0">

                        <DataGrid.Columns>
                            <!-- Type badge -->
                            <DataGridTemplateColumn Header="Type" Width="70" IsReadOnly="True" SortMemberPath="TypeLabel">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TypeBadge}"
                                                Background="{Binding TypeLabel, Converter={StaticResource TypeToColorConverter}}">
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="White"
                                                       FontWeight="Bold" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Instance -->
                            <DataGridTextColumn Header="Instance" Binding="{Binding Instance}" Width="72" IsReadOnly="True"/>

                            <!-- Name -->
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>

                            <!-- Present Value (editable) -->
                            <DataGridTemplateColumn Header="Present Value" Width="140" SortMemberPath="PresentValue">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayValue}"
                                                   Foreground="{StaticResource AccentGreen}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PresentValue, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="{StaticResource BgInput}"
                                                 Foreground="{StaticResource AccentGreen}"
                                                 Padding="4,2" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Units -->
                            <DataGridTextColumn Header="Units" Binding="{Binding Units}" Width="80" IsReadOnly="True"/>

                            <!-- Generation mode (analog) -->
                            <DataGridTextColumn Header="Generation" Binding="{Binding SimulationLabel}" Width="90" IsReadOnly="True"/>

                            <!-- Description -->
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="140" IsReadOnly="True"/>

                            <!-- OOS toggle -->
                            <DataGridTemplateColumn Header="Out of Service" Width="100" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding OutOfService, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="{StaticResource TextMuted}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 2 – Log panel
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,10,16,0" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#181B29" CornerRadius="10,10,0,0" Padding="14,6">
                    <Grid>
                        <TextBlock Text="📟  Activity Log" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <Button Content="Clear" HorizontalAlignment="Right" Style="{StaticResource BtnGhost}"
                                Command="{Binding ClearLogCommand}" Height="22" Padding="10,2" FontSize="11"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                              Background="#13151F" Padding="12,6">
                    <TextBlock x:Name="LogBlock"
                               Text="{Binding LogText}" Foreground="#6EE7B7"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 3 – Status bar
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource BgPanel}" Padding="16,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMuted}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="BACnet/IP · UDP 47808" HorizontalAlignment="Right"
                           Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
